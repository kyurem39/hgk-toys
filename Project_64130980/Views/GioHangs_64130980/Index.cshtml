@model IEnumerable<Project_64130980.Models.GioHang>

@{
    ViewBag.Title = "Đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var grid = new WebGrid(Model, canPage: true, defaultSort: "SoHD", rowsPerPage: 5);
}

<h2>Danh sách đơn hàng</h2>

@{
    // Tạo danh sách các giá trị TinhTrang
    var tinhTrangValues = new List<SelectListItem>
{
        new SelectListItem { Text = "Đã tạo đơn", Value = "0" }, // Tình trạng 0
        new SelectListItem { Text = "Đang giao hàng", Value = "1" }, // Tình trạng 1
        new SelectListItem { Text = "Giao hàng thành công", Value = "2" } // Tình trạng 2
    };
}

<form method="get">
    @Html.DropDownList("TinhTrang", tinhTrangValues, "Tất cả", new { @class = "form-control", onchange = "this.form.submit();" })
</form>

<hr/>
<p>
    @Html.ActionLink("Thêm", "Create", null, new { @class = "btn btn-outline-success", @style = "padding: 10px 20px;" })
</p>

<head>
    <style type="text/css">
        .grid-footer {
            color: #000;
            font: 17px Calibri;
            text-align: center;
            font-weight: bold;
        }

            .grid-footer a {
                background-color: #ffffff;
                color: blue;
                box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2);
                padding: 1px 10px 2px 10px;
            }

                .grid-footer a:active, a:hover {
                    color: #FFAD33;
                    box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2);
                }

        .alternatingRowStyle {
            background-color: aliceblue;
        }

        table .table1 {
            text-align: left;
            margin-left: 0px;
            margin-right: 0px;
            width: 800px;
        }

        .tr, .td {
            text-align: left;
        }
    </style>
</head>

<div id="gridContent">
    @ViewBag.TB
    @grid.GetHtml(
        tableStyle: "table table-bordered table-hover",
        footerStyle: "grid-footer",
        fillEmptyRows: true,
        mode: WebGridPagerModes.Numeric,
        alternatingRowStyle: "alternatingRowStyle",
        columns: new[]
        {
        grid.Column("STT",format: item => item.WebGrid.Rows.IndexOf(item) + 1 + Math.Round(Convert.ToDouble(grid.TotalRowCount / grid.PageCount) / grid.RowsPerPage) * grid.RowsPerPage * grid.PageIndex),
        grid.Column("SoHD","Số hoá đơn"), //the model fields to display
        grid.Column("NgayDatHang","Ngày đặt hàng"),
        grid.Column("Khách hàng", format: item => item.KhachHang.HoTen),
        grid.Column("Nhân viên giao", format: item => item.NhanVien.HoTen),
        grid.Column("TongTien", "Tổng tiền", format: @<text>@string.Format("{0:0,0}", @item.TongTien)</text>),
grid.Column("LoaiThanhToan", "Loại thanh toán",format: (@item) => @item.LoaiThanhToan==true?"Tiền mặt":"Chuyển khoản"),
grid.Column("Tình trạng", format:@<text>
            @{
        var tinhTrangMapping = new Dictionary<int, string>
                                                                        {
            { 0, "Đã tạo đơn" },
            { 1, "Đang giao hàng" },
            { 2, "Giao hàng thành công" }
        };

        string tinhTrangMoTa = tinhTrangMapping.ContainsKey((int)@item.TinhTrang)
            ? tinhTrangMapping[(int)@item.TinhTrang]
            : "Không xác định";
            }
            @tinhTrangMoTa
</text>),

grid.Column("Chức năng", format:
@<text>
    <a href="@Url.Action("Edit", new { id = item.SoHD})" class="edit-btn"><abbr title="Cập nhật dữ liệu"><img src="~/Images/Action/edit.png" width="20" height="20" /></abbr></a>
    <a href="@Url.Action("Details", new { id = item.SoHD})" class="edit-btn"><abbr title="Xem chi tiết"><img src="~/Images/Action/details.png" width="20" height="20" /></abbr></a>
    <a href="@Url.Action("Delete", new { id = item.SoHD})" class="edit-btn"><abbr title="Xóa dữ liệu"><img src="~/Images/Action/delete.png" width="20" height="20" /></abbr></a>
</text>),
}
)
</div>