@model Project_64130980.Models.GioHang

@{
    ViewBag.Title = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string thanhtoan = "0";
    string tinhtrang = "0";
    int i = 0;
}

<h2>Thông tin đơn hàng</h2>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            Ngày đặt hàng
        </dt>

        <dd>
            @Html.DisplayFor(model => model.NgayDatHang)
        </dd>

        <dt>
            Khách hàng
        </dt>

        <dd>
            @Html.DisplayFor(model => model.KhachHang.HoTen)
        </dd>

        <dt>
            Nhân viên giao hàng
        </dt>

        <dd>
            @Html.DisplayFor(model => model.NhanVien.HoTen)
        </dd>

        <dt>
            Tổng tiền
        </dt>

        <dd>
            @string.Format("{0:0,0}", @Model.TongTien)
        </dd>

        <dt>
            Loại thanh toán
        </dt>

        <dd>
            @{if (Model.LoaiThanhToan == true)
                {
                    thanhtoan = "Tiền mặt";
                }
                else
                {
                    thanhtoan = "Chuyển khoản";
                }
            }
            @thanhtoan
        </dd>

        <dt>
            Tình trạng
        </dt>

        <dd>
            @{if (Model.TinhTrang == 0)
                {
                    tinhtrang = "Đã tạo đơn";
                }
                else if (Model.TinhTrang == 1)
                {
                    tinhtrang = "Đang giao hàng";
                }
                else if (Model.TinhTrang == 2)
                {
                    tinhtrang = "Giao hàng thành công";
                }
            }
            @tinhtrang
        </dd>
    </dl>

    <hr />
    <h4>Chi tiết</h4>
    @if (Model.ChiTietGioHangs != null && Model.ChiTietGioHangs.Any())
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>@Html.DisplayName("Tên sản phẩm")</th>
                    <th>@Html.DisplayName("Số lượng")</th>
                    <th>@Html.DisplayName("Đơn giá")</th>
                    <th>@Html.DisplayName("Thành tiền")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.ChiTietGioHangs)
                {
                    i++;
                    <tr>
                        <td>@i</td>
                        <td>@item.SanPham.TenSP</td>
                        <td>@item.SoLuong</td>
                        <td>@item.DonGiaBan</td>
                        <td>@(item.SoLuong * item.DonGiaBan)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">Không có chi tiết đơn hàng nào.</p>
    }
</div>
<p>
    @Html.ActionLink("Sửa", "Edit", new { id = Model.SoHD }) |
    @Html.ActionLink("Quay lại", "Index")
</p>