@model Project_64130980.Models.GioHang

@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int i = 0;
}

<h2>Sửa thông tin</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @Html.HiddenFor(model => model.SoHD)
        @Html.HiddenFor(model => model.NgayDatHang)

        <div class="form-group">
            @Html.LabelFor(model => model.MaKH, "Khách hàng", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("MaKH", null, htmlAttributes: new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.MaKH, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.MaNVGiaoHang, "Nhân viên giao hàng", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("MaNVGiaoHang", null, htmlAttributes: new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.MaNVGiaoHang, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.TongTien, "Tổng tiền", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DisplayFor(model => model.TongTien, new { @class = "form-control" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.LoaiThanhToan, "Loại thanh toán", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                <div class="checkbox">
                    Tiền mặt @Html.RadioButtonFor(model => model.LoaiThanhToan, "True", new { @checked = "checked" }) &nbsp;
                    Chuyển khoản @Html.RadioButtonFor(model => model.LoaiThanhToan, "False")
                    @Html.ValidationMessageFor(model => model.LoaiThanhToan, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.TinhTrang, "Tình trạng", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                <div class="checkbox">
                    Đã tạo đơn @Html.RadioButtonFor(model => model.TinhTrang, "0", new { @checked = "checked" }) &nbsp;
                    Đang giao hàng @Html.RadioButtonFor(model => model.TinhTrang, "1") &nbsp;
                    Giao hàng thành công @Html.RadioButtonFor(model => model.TinhTrang, "2")
                    @Html.ValidationMessageFor(model => model.TinhTrang, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>

        <hr />
        <h4>Chi tiết</h4>
        @if (Model.ChiTietGioHangs != null && Model.ChiTietGioHangs.Any())
        {
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>@Html.DisplayName("Tên sản phẩm")</th>
                        <th>@Html.DisplayName("Số lượng")</th>
                        <th>@Html.DisplayName("Đơn giá")</th>
                        <th>@Html.DisplayName("Thành tiền")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ChiTietGioHangs)
                    {
                        i++;
                        <tr>
                            <td>@i</td>
                            <td>@item.SanPham.TenSP</td>
                            <td>@item.SoLuong</td>
                            <td>@item.DonGiaBan</td>
                            <td>@(item.SoLuong * item.DonGiaBan)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Không có chi tiết đơn hàng nào.</p>
        }

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Lưu" class="btn btn-primary" />
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("Quay lại", "Index")
</div>