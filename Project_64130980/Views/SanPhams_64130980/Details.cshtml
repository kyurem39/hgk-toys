@model Project_64130980.Models.SanPham

@{
    ViewBag.Title = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Thông tin sản phẩm</h2>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            Ảnh sản phẩm
        </dt>

        <dd>
            <img src="@Html.DisplayFor(model => model.AnhSanPham)" width="100" height="100" /> <br />
            @Html.DisplayFor(model => model.AnhSanPham)
        </dd>

        <dt>
            Tên sản phẩm
        </dt>

        <dd>
            @Html.DisplayFor(model => model.TenSP)
        </dd>

        <dt>
            Mô tả
        </dt>

        <dd>
            @Html.DisplayFor(model => model.MoTa)
        </dd>

        <dt>
            Số lượng
        </dt>

        <dd>
            @Html.DisplayFor(model => model.SoLuong)
        </dd>

        <dt>
            Đon vị tính
        </dt>

        <dd>
            @Html.DisplayFor(model => model.DonViTinh)
        </dd>

        <dt>
            Đơn giá (VNĐ)
        </dt>

        <dd>
            @string.Format("{0:0,0}", @Model.DonGia)
        </dd>

        <dt>
            Loại sản phẩm
        </dt>

        <dd>
            @Html.DisplayFor(model => model.LoaiSanPham.TenLoaiSP)
        </dd>

    </dl>
</div>
<p>
    @Html.ActionLink("Sửa", "Edit", new { id = Model.MaSP }) |
    @Html.ActionLink("Quay lại", "Index")
</p>
