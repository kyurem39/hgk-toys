@model IEnumerable<Project_64130980.Models.SanPham>

@{
    ViewBag.Title = "Sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var grid = new WebGrid(Model, canPage: true, defaultSort: "MaSP", rowsPerPage: 5);
}

<h2>Danh sách sản phẩm</h2>

@using (Html.BeginForm("TimKiemSanPham", "SanPhams_64130980", FormMethod.Get, new { id = "timKiemForm" }))
{
    <div class="form-group d-flex flex-column flex-sm-row align-items-center justify-content-between">
        <div class="input-group" style="flex: 1; min-width: 200px;">
            <input type="text" id="tuKhoa" name="tuKhoa" class="form-control" placeholder="Nhập tên sản phẩm" value="@ViewBag.TuKhoa" />
            <span class="input-group-btn">
                <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                @Html.ActionLink("Làm mới", "Index", null, new { @class = "btn btn-secondary" })
            </span>
        </div>

        <!-- Dropdown list sẽ hiển thị dưới thanh tìm kiếm khi thu nhỏ màn hình -->
        <div class="ml-3 mt-3 mt-sm-0">
            @Html.DropDownList("loaiSanPham", (SelectList)ViewBag.LoaiSanPham, "Tất cả", new { @class = "form-control", id = "loaiSanPham" })
        </div>
    </div>
}

<hr />

<p>
    @Html.ActionLink("Thêm", "Create", null, new { @class = "btn btn-outline-success", @style = "padding: 10px 20px;" })
</p>

<head>
    <style type="text/css">
        .grid-footer {
            color: #000;
            font: 17px Calibri;
            text-align: center;
            font-weight: bold;
        }

            .grid-footer a {
                background-color: #ffffff;
                color: blue;
                box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2);
                padding: 1px 10px 2px 10px;
            }

                .grid-footer a:active, a:hover {
                    color: #FFAD33;
                    box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2);
                }

        .alternatingRowStyle {
            background-color: aliceblue;
        }

        table .table1 {
            text-align: left;
            margin-left: 0px;
            margin-right: 0px;
            width: 800px;
        }

        .tr, .td {
            text-align: left;
        }
    </style>
</head>

<div id="gridContent">
    @ViewBag.TB
    @grid.GetHtml(
        tableStyle: "table table-bordered table-hover",
        footerStyle: "grid-footer",
        fillEmptyRows: true,
        mode: WebGridPagerModes.Numeric,
        alternatingRowStyle: "alternatingRowStyle",
        columns: new[]
        {
        grid.Column("STT", format: item => item.WebGrid.Rows.IndexOf(item) + 1 + Math.Round(Convert.ToDouble(grid.TotalRowCount / grid.PageCount) / grid.RowsPerPage) * grid.RowsPerPage * grid.PageIndex),
        grid.Column("MaSP","Mã"), //the model fields to display
        grid.Column("Ảnh", format: @<img src="@Url.Content(item.AnhSanPham)" width="70" height="70" />),
grid.Column("TenSP","Tên sản phẩm"),
grid.Column("MoTa","Mô tả"),
grid.Column("SoLuong","Số lượng"),
grid.Column("DonViTinh","Đơn vị"),
grid.Column("DonGia", "Giá (VNĐ)", format: @<text>@string.Format("{0:0,0}", @item.DonGia)</text>),
grid.Column("Loại sản phẩm", format: item => item.LoaiSanPham.TenLoaiSP),
grid.Column("Chức năng", format:
@<text>
    <a href="@Url.Action("Edit", new { id = item.MaSP})" class="edit-btn"><abbr title="Cập nhật dữ liệu"><img src="~/Images/Action/edit.png" width="20" height="20" /></abbr></a>
    <a href="@Url.Action("Details", new { id = item.MaSP})" class="edit-btn"><abbr title="Xem chi tiết"><img src="~/Images/Action/details.png" width="20" height="20" /></abbr></a>
    <a href="@Url.Action("Delete", new { id = item.MaSP})" class="edit-btn"><abbr title="Xóa dữ liệu"><img src="~/Images/Action/delete.png" width="20" height="20" /></abbr></a>
</text>),
}
)
</div>

<script>
    document.getElementById("loaiSanPham").addEventListener("change", function () {
        var selectedValue = this.value;
        var loaiSanPhamInput = document.createElement("loaiSanPham");

        if (selectedValue === "") {
            // Nếu chọn "Tất cả", làm mới form
            loaiSanPham.value = "";
            document.getElementById("timKiemForm").submit();
        } else {
            // Gán giá trị của dropdown vào input 'tuKhoa' và submit
            loaiSanPhamInput.value = selectedValue;
            document.getElementById("timKiemForm").submit();
        }
    });</script>